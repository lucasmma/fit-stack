// Generator + datasource only. Module-specific models live in their own
// `<module>.prisma` files and are merged via Prisma's multi-file schema feature.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
