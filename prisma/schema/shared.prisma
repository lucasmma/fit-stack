model Profile {
  id        String   @id @db.Uuid
  email     String   @unique
  fullName  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plans           Plan[]
  sessions        Session[]
  photos          ProgressPhoto[]
  shareLinks      ShareLink[]
  customExercises Exercise[]

  @@map("profiles")
}
